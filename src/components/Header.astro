---
// Header.astro
import Nav from "./Nav.astro"

interface Props {
  title?: string;
}

const { title } = Astro.props;
console.log({title});
---
<header class="flex justify-between items-center">
    <a href="#"><img src="/images/logo.webp" alt="Bien Común" class="w-32" /></a>
    <!-- Aquí puedes agregar otros elementos del header -->
    <h1><a href="#">{title}</a></h1>
    <Nav />
</header>
<style>
    a {
        opacity: 1;
    }
    a:hover {
        opacity: 0.7;
    }
</style>